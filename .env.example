# Hospitality Agents — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.

# ─── Next.js ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Clerk (auth) ────────────────────────────────────────────────────────
# Sign up: https://dashboard.clerk.com
# Create an app → Invite-only mode → copy keys from API Keys page
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook secret for the user.created event → mirrors Clerk users into Supabase
CLERK_WEBHOOK_SECRET=

# ─── Supabase (Postgres + Storage) ──────────────────────────────────────
# Sign up: https://supabase.com/dashboard
# Create a project → Project Settings → API → copy URL + keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is SERVER-ONLY; never import into a client component
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Claude — copy generation) ───────────────────────────────
# Sign up: https://console.anthropic.com
# Create an API key → enable prompt caching on brand guide system prompt
ANTHROPIC_API_KEY=

# ─── fal.ai (Flux — image enhancement) ──────────────────────────────────
# Sign up: https://fal.ai/dashboard
# Models used: fal-ai/flux/dev/image-to-image, fal-ai/flux-pro/v1.1, fal-ai/topaz-upscaler
FAL_KEY=

# ─── Creatomate (video assembly) ────────────────────────────────────────
# Sign up: https://creatomate.com
# Design templates in the visual editor → drive renders via REST API
CREATOMATE_API_KEY=

# ─── Sentry (error tracking — optional for MVP) ─────────────────────────
# Sign up: https://sentry.io
SENTRY_DSN=
